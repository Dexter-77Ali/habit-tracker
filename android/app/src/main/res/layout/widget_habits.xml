<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/w_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/w_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Life Tracker"
            android:textColor="#F3EEE3"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/w_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E3B072"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView android:id="@+id/w_row0" style="@style/WidgetHabitRow" />
    <TextView android:id="@+id/w_row1" style="@style/WidgetHabitRow" />
    <TextView android:id="@+id/w_row2" style="@style/WidgetHabitRow" />
    <TextView android:id="@+id/w_row3" style="@style/WidgetHabitRow" />
    <TextView android:id="@+id/w_row4" style="@style/WidgetHabitRow" />
    <TextView android:id="@+id/w_row5" style="@style/WidgetHabitRow" />

</LinearLayout>
